/* pages/index/index.wxss */
.brand-card {
  padding: 40rpx 30rpx;
}

.brand-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B6B;
  margin-bottom: 10rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: #999;
}

.relation-select {
  padding: 20rpx 0;
}

.relation-select .label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.relation-group {
  display: flex;
  flex-wrap: wrap;
}

.relation-group .van-radio {
  margin-right: 40rpx;
  margin-bottom: 10rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-names {
  font-size: 28rpx;
  color: #333;
}

.history-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.btn-more {
  background: none;
  border: 1rpx solid #FF6B6B;
  color: #FF6B6B;
  border-radius: 50rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  line-height: 1;
}

.btn-more::after {
  border: none;
}

.remaining-hint {
  padding: 10rpx 0;
}

.remaining-text {
  font-size: 26rpx;
  color: #999;
}

.remaining-count {
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 6rpx;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

