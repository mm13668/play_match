/* pages/index/index.wxss */
.brand-card {
  padding: 40rpx 30rpx;
}

.brand-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B6B;
  margin-bottom: 10rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: #999;
}

.relation-select {
  padding: 30rpx 0;
}

.relation-select .label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.relation-group {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  flex-wrap: nowrap;
  align-items: center;
}

.relation-item {
  flex: 1;
  text-align: center;
  line-height: 60rpx;
  margin: 0 8rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 28rpx;
}

.relation-item:first-child {
  margin-left: 0;
}

.relation-item:last-child {
  margin-right: 0;
}

.relation-item.active {
  background-color: #FF6B6B;
  color: #fff;
}

.history-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-names {
  font-size: 28rpx;
  color: #333;
}

.history-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.btn-more {
  background: none;
  border: 1rpx solid #FF6B6B;
  color: #FF6B6B;
  border-radius: 50rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  line-height: 1;
}

.btn-more::after {
  border: none;
}

.remaining-hint {
  padding: 10rpx 0;
}

.remaining-text {
  font-size: 26rpx;
  color: #999;
}

.remaining-count {
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 6rpx;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-ad {
  background: none;
  border: 1rpx solid #FF6B6B;
  color: #FF6B6B;
  border-radius: 50rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  line-height: 1;
  display: inline-block;
}

.btn-ad::after {
  border: none;
}

/* 丢纸条入口卡片 */
.note-card {
  padding: 30rpx;
  background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
  border-radius: 16rpx;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.note-header .note-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.note-header .note-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.note-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.note-tag text {
  font-size: 22rpx;
  color: white;
}

