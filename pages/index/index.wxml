<!--pages/index/index.wxml-->
<view class="container">
  <!-- 品牌区 -->
  <view class="brand-card card text-center">
    <view class="brand-title">去玩匹配</view>
    <view class="brand-slogan text-gray">测一测你们的默契指数</view>
  </view>

  <!-- 测试表单 -->
  <view class="form-card card mt-20">
    <view class="input-item">
      <van-field
        value="{{person1Name}}"
        label="第一个人"
        placeholder="请输入姓名"
        bind:input="onPerson1Input"
        maxlength="10"
      />
    </view>

    <view class="input-item mt-20">
      <van-field
        value="{{person2Name}}"
        label="第二个人"
        placeholder="请输入姓名"
        bind:input="onPerson2Input"
        maxlength="10"
      />
    </view>

     <view class="relation-select mt-20">
       <view class="label">关系类型</view>
       <view class="relation-group">
         <view 
           class="relation-item {{relationType === '1' ? 'active' : ''}}" 
           bindtap="selectRelation" 
           data-value="1"
         >
           情侣
         </view>
         <view 
           class="relation-item {{relationType === '2' ? 'active' : ''}}" 
           bindtap="selectRelation" 
           data-value="2"
         >
           朋友
         </view>
         <view 
           class="relation-item {{relationType === '3' ? 'active' : ''}}" 
           bindtap="selectRelation" 
           data-value="3"
         >
           同事
         </view>
         <view 
           class="relation-item {{relationType === '4' ? 'active' : ''}}" 
           bindtap="selectRelation" 
           data-value="4"
         >
           家人
         </view>
       </view>
     </view>
  </view>

  <!-- 剩余次数提示 -->
  <view class="remaining-hint text-center mt-20">
    <text class="remaining-text" wx:if="{{remainingShells > 0}}">剩余 <text class="remaining-count text-primary">{{remainingShells}}</text> 次</text>
    <text class="remaining-text" wx:if="{{remainingShells <= 0 }}">次数已用完</text>
  </view>
  
  <!-- 看广告增加次数 -->
  <view wx:if="{{remainingShells <= 0 }}" class="text-center mt-10">
    <button class="btn-ad" bindtap="onWatchAd">看广告获取次数</button>
  </view>

  <!-- 开始测试按钮 -->
  <view class="mt-10">
    <button class="btn-primary" bindtap="onStartTest" disabled="{{remainingShells <= 0 }}">开始匹配测试</button>
  </view>

   <!-- 丢纸条入口 -->
   <view class="note-card card mt-30" bindtap="onGoNote">
     <view class="note-header">
       <view class="note-title">丢纸条</view>
       <view class="note-subtitle">匿名传递悄悄话 · 有缘人千里一线牵</view>
     </view>
     <view class="note-tag">
       <text>消耗1贝壳</text>
     </view>
   </view>

   <!-- 历史记录 -->
   <view wx:if="{{historyRecords.length > 0}}" class="history-card card mt-30">
     <view class="history-title">最近测试记录</view>
     <view class="history-list">
        <view 
          wx:for="{{historyRecords}}" 
          wx:key="_id"
          class="history-item"
          bindtap="onHistoryTap"
          data-id="{{item._id}}"
        >
         <view class="history-names">{{item.person1_name}} & {{item.person2_name}}</view>
         <view class="history-score">{{item.match_score}}分</view>
       </view>
     </view>
     <view class="text-center mt-20">
       <button class="btn-more" bindtap="onGoMy">查看全部</button>
     </view>
   </view>
 </view>
