/* pages/result/result.wxss */
.score-card {
  padding: 40rpx 30rpx;
}

.score-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.score-value {
  font-size: 96rpx;
  font-weight: bold;
  color: #FF6B6B;
  line-height: 1;
  margin-bottom: 20rpx;
}

.score-desc {
  font-size: 32rpx;
  color: #FF6B6B;
}

.result-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.blur-content {
  font-size: 48rpx;
  color: #ccc;
  letter-spacing: 8rpx;
  filter: blur(2rpx);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-buttons button {
  flex: 1;
}

.btn-secondary {
  background: white;
  border: 1rpx solid #FF6B6B;
  color: #FF6B6B;
  border-radius: 50rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
}

.btn-secondary::after {
  border: none;
}

.loading-container {
  font-size: 28rpx;
  color: #999;
  padding: 100rpx 0;
}

/* 分享海报弹窗 - 居中弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex !important;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 30rpx;
  box-sizing: border-box;
}

.poster-content {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 85vw;
  max-height: 80vh;
  overflow: hidden;
}

.poster-canvas {
  width: 100%;
  height: auto;
  border-radius: 20rpx 20rpx 0 0;
  background-color: #ffffff;
  box-sizing: border-box;
}

.poster-actions {
  width: 100%;
  padding: 15rpx 15rpx 20rpx;
  box-sizing: border-box;
}

.poster-content {
  background: #ffffff;
  width: 100%;
  max-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.poster-canvas {
  flex-shrink: 1;
  width: auto;
  max-width: 100%;
  height: auto;
  max-height: calc(100vh - 140rpx - env(safe-area-inset-bottom));
  border-radius: 10rpx;
  background-color: #f8f8f8;
  box-sizing: border-box;
}

.poster-actions {
  flex-shrink: 0;
  width: 100%;
  max-width: 600px;
  margin-top: 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
