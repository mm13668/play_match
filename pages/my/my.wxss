/* pages/my/my.wxss */
.container {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 25%, #ffecd2 50%, #fccde2 75%, #a18cd1 100%);
  background-size: 400% 400%;
  overflow-x: hidden;
  animation: gradientShift 15s ease infinite;
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.card {
  border-radius: 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(255, 107, 107, 0.15);
  backdrop-filter: blur(20rpx);
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  position: relative;
}

.mt-20 {
  margin-top: 24rpx;
}

.user-card {
  padding: 36rpx 30rpx;
}

.login-box {
  text-align: center;
  padding: 20rpx 0;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  border: 4rpx solid #FF6B6B;
  padding: 4rpx;
  background: #fff;
}

.default-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #FF6B6B, #ff8a8a);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.user-info-text .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.user-info-text .stats {
  font-size: 28rpx;
  color: #666;
  font-weight: 400;
}

.shell-count {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 600;
  margin: 0 6rpx;
}

.arrow-icon {
  margin-left: auto;
  display: flex;
  align-items: center;
}

.arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #C8C9CC;
  border-right: 2rpx solid #C8C9CC;
  transform: rotate(45deg);
}

.vip-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid #FF6B6B;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

.count {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
  margin-right: 10rpx;
}

.menu-card {
  padding: 0;
}

.menu-card .van-cell-group {
  margin: 0;
}

.menu-card .van-cell {
  padding: 32rpx 30rpx;
  font-size: 30rpx;
}

.menu-card .van-cell::after {
  left: 30rpx;
  right: 30rpx;
}

/* 快速入口 */
.quick-actions {
  display: flex;
  padding: 0;
}

.action-item {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-right: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.action-item:active {
  background: rgba(255, 107, 107, 0.05);
}

.action-item:last-child {
  border-right: none;
}

.action-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.action-arrow {
  font-size: 28rpx;
  color: #C8C9CC;
}

/* 退出登录文字红色 */
.van-cell[title="退出登录"] .van-cell__title {
  color: #ff4d4f;
}

.bottom-spacing {
  height: 60rpx;
}
