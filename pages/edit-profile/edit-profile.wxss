.container {
  padding: 0 0 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  background: linear-gradient(180deg, #FF6B6B 0%, #ff8585 100%);
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-wrapper:active .avatar-mask {
  opacity: 1;
}

.mask-text {
  color: #fff;
  font-size: 24rpx;
}

/* 表单区域 */
.form-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 性别区域 */
.gender-section {
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #f5f5f5;
  display: flex;
  align-items: center;
}

.gender-label {
  font-size: 28rpx;
  color: #333;
  width: 140rpx;
  flex-shrink: 0;
}

/* 按钮区域 */
.button-section {
  margin: 40rpx 20rpx 0;
}

/* 占位 */
.default-avatar {
  background-color: #e0e0e0;
}
