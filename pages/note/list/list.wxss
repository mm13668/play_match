.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.list-container {
  padding: 20rpx;
}

.note-item {
  background: white;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.note-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.sender {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  color: #999;
  line-height: 1.2;
}

.status.unread {
  background-color: #ff6b6b;
  color: white;
  font-weight: 500;
}

.note-content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 20rpx;
  padding: 8rpx 0;
}

.note-footer {
  text-align: right;
  padding-top: 8rpx;
  border-top: 1rpx solid #f5f5f5;
}

.time {
  font-size: 24rpx;
  color: #bbb;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 20rpx calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.bottom-action .van-button--primary {
  background-color: #FF6B6B;
  border-color: #FF6B6B;
}
