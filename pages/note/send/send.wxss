.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.warning-card {
  padding: 30rpx;
  background: #fff3f0;
  border-radius: 12rpx;
  text-align: center;
}

.warning-text {
  display: block;
  color: #ff6b6b;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.value.warning {
  color: #ff4d4f;
}

.input-container {
  position: relative;
  margin-bottom: 30rpx;
}

textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.count {
  text-align: right;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.ad-tip {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #fff9e6;
  border-radius: 8rpx;
  text-align: center;
}

.ad-tip text {
  display: block;
  font-size: 26rpx;
  color: #faad14;
  margin-bottom: 15rpx;
}
