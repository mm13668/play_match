.container {
  padding: 0;
  min-height: 100vh;
  background: linear-gradient(180deg, #ffeef0 0%, #ffd6e0 100%);
  position: relative;
  overflow: hidden;
}

.background-pool {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100vh;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
}

.avatar-item {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  border: 4rpx solid rgba(255, 107, 107, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0);
  }
  25% {
    transform: translate(-10rpx, -10rpx);
  }
  50% {
    transform: translate(5rpx, -20rpx);
  }
  75% {
    transform: translate(10rpx, -10rpx);
  }
}

.card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.15);
  position: relative;
  z-index: 1;
  margin: 20rpx;
  backdrop-filter: blur(10rpx);
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.warning-card {
  padding: 30rpx;
  background: #fff3f0;
  border-radius: 12rpx;
  text-align: center;
}

.warning-text {
  display: block;
  color: #ff6b6b;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.rules-card {
  background: #fff8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #ffe0e0;
}

.rules-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B6B;
  margin-bottom: 16rpx;
}

.rules-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 4rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.value.warning {
  color: #ff4d4f;
}

.input-container {
  position: relative;
  margin-bottom: 30rpx;
}

textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.count {
  text-align: right;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.ad-tip {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #fff9e6;
  border-radius: 8rpx;
  text-align: center;
}

.ad-tip text {
  display: block;
  font-size: 26rpx;
  color: #faad14;
  margin-bottom: 15rpx;
}
