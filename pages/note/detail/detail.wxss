.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.content {
  padding-bottom: 40rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.sender-info,
.time-info {
  display: flex;
  margin-bottom: 16rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 24rpx 0;
}

.note-content,
.reply-content {
  margin-top: 20rpx;
}

.content-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.content-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
  white-space: pre-wrap;
}

.reply-time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.action-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.action-card .tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.match-card {
  border: 2rpx solid #07c160;
}

.ad-tip {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fff9e6;
  border-radius: 8rpx;
  text-align: center;
}

.ad-tip text {
  display: block;
  font-size: 26rpx;
  color: #faad14;
  margin-bottom: 12rpx;
}

.reply-popup {
  width: 100vw;
  padding: 30rpx;
  box-sizing: border-box;
  background: white;
  border-radius: 16rpx 16rpx 0 0;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.popup-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.popup-header .cancel {
  font-size: 28rpx;
  color: #666;
}

.reply-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  margin-bottom: 10rpx;
}

.popup-header .count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}
