.container {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #ffeef0 0%, #ffd6e0 100%);
  padding: 20rpx;
}

.background-pool {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100vh;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
}

.bubble-item {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  border: 4rpx solid rgba(255, 107, 107, 0.2);
  animation: bubbleFloat 4s ease-in-out infinite;
}

@keyframes bubbleFloat {
  0%, 100% {
    transform: translate(0, 0);
  }
  25% {
    transform: translate(-8rpx, -8rpx);
  }
  50% {
    transform: translate(4rpx, -16rpx);
  }
  75% {
    transform: translate(8rpx, -8rpx);
  }
}

.content {
  position: relative;
  z-index: 1;
  padding-bottom: 40rpx;
}

.card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.15);
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.sender-info,
.receiver-info,
.time-info {
  display: flex;
  margin-bottom: 20rpx;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
  font-weight: 400;
}

.value {
  font-size: 30rpx;
  color: #FF6B6B;
  font-weight: 500;
  flex: 1;
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 30rpx 0;
}

.note-content,
.reply-content {
  margin-top: 20rpx;
}

.content-label {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.content-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
  background: linear-gradient(135deg, #fdfdfd 0%, #f9f9f9 100%);
  padding: 24rpx;
  border-radius: 12rpx;
  white-space: pre-wrap;
  border: 1rpx solid #f0f0f0;
}

.reply-time {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.action-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.12);
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-card .tip {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.match-card {
  border: 2rpx solid #FF6B6B;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.03) 0%, rgba(255, 107, 107, 0.08) 100%);
}

.ad-tip {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fff9e6;
  border-radius: 8rpx;
  text-align: center;
}

.ad-tip text {
  display: block;
  font-size: 26rpx;
  color: #faad14;
  margin-bottom: 12rpx;
}

.reply-popup {
  width: 100vw;
  padding: 30rpx;
  box-sizing: border-box;
  background: white;
  border-radius: 16rpx 16rpx 0 0;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.popup-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.popup-header .cancel {
  font-size: 28rpx;
  color: #666;
}

.reply-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  margin-bottom: 10rpx;
}

.popup-header .count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.bottom-spacing {
  height: 60rpx;
}
